{
        "compilerOptions": {
                "lib": ["ESNext", "DOM"],
                "target": "ESNext",
                "module": "ESNext",
                "esModuleInterop": true,
                "moduleResolution": "bundler",
                "forceConsistentCasingInFileNames": true,
                "strict": true,
                "skipLibCheck": true,
                "ignoreDeprecations": "6.0"
        }
}
